# ============================================================================
# Milvus quickstart 环境变量模板
# ----------------------------------------------------------------------------
# 用法：
#   1) cp .env.example .env
#   2) 按需修改下面的值
#   3) 任何脚本（python -m src.test2_scalar_filter.prepare_dataset ...）启动时
#      会自动 load_dotenv() 加载 .env（详见 src/common/config.py）
#
# 优先级：CLI 参数  >  环境变量 (.env)  >  代码默认值
# ============================================================================


# ----------------------------------------------------------------------------
# 【常改 · 推荐放 .env】Milvus 连接
# ----------------------------------------------------------------------------
MILVUS_URI=http://localhost:19530
# 仅 Zilliz Cloud / 启用了鉴权时需要：
# MILVUS_TOKEN=
# MILVUS_DB=default


# ----------------------------------------------------------------------------
# 【常改 · 推荐放 .env】数据规模与维度
# ----------------------------------------------------------------------------
# Collection 名（不同测试场景之间换名字，避免互相覆盖）
COLLECTION_NAME=scalar_filter_test

# embedding 维度。配合 text-embedding-3-large = 3072
DIM=3072

# 总行数。先用小规模跑通，再上 10M
# 小规模 smoke: 50_000；中等: 1_000_000；生产规模: 10_000_000
NUM_ROWS=50000

# 单批 insert 行数。3072 dim 时建议 5000~50000，太大会撑爆 client buffer
INSERT_BATCH=10000

# 每多少 batch 触发一次 flush
FLUSH_EVERY=20

# 输出目录（CSV、manifest、日志）
RESULTS_DIR=./results
LOG_LEVEL=INFO
SEED=42


# ----------------------------------------------------------------------------
# 【常改 · 推荐放 .env】文档切片模型
# ----------------------------------------------------------------------------
# 业务模型：每个文档随机出 [min,max] 个 chunk（均匀）。
# 同一文档的所有 chunk 共享 documentId / kbId / study / site / patient / visit。
# NUM_ROWS=10M & chunks~U(20,500) 下预期文档数 ≈ 38,500。
CHUNKS_PER_DOC_MIN=20
CHUNKS_PER_DOC_MAX=500


# ----------------------------------------------------------------------------
# 【常改 · 推荐放 .env】标量字段基数与分布
# ----------------------------------------------------------------------------
# kbId 基数（业务侧 ~10 个知识库）。同时作为 partition_key（见 SCALAR_PLAN=S5）。
KB_CARD=10
# 每个字段的 distinct 值数量（用户场景：都是几十）
STUDY_CARD=30
SITE_CARD=30
PATIENT_CARD=30
VISIT_CARD=30

# 分布偏斜度：0=均匀；1.0~1.5=明显偏斜（更接近真实热点数据）。同时作用于 kbId / study / ...
ZIPF_ALPHA=1.0

# content 占位串长度（仅 output，不参与过滤）
CONTENT_LEN=256


# ----------------------------------------------------------------------------
# 【常改 · 推荐放 .env】索引方案
# ----------------------------------------------------------------------------
# 向量索引：HNSW / IVF_FLAT
VEC_INDEX=HNSW
VEC_METRIC=IP
HNSW_M=16
HNSW_EFC=200
IVF_NLIST=4096

# 标量索引方案：S0~S5
#   S0 = 都不建（baseline）
#   S1 = documentId(INVERTED) + kbId(BITMAP)
#   S2 = 低基数(BITMAP) + kbId(BITMAP)
#   S3 = documentId(INVERTED) + 低基数(BITMAP) + kbId(BITMAP)
#   S4 = 全 INVERTED
#   S5 = 与 S3 同但 kbId 作为 partition_key（num_partitions=16）——生产首选
SCALAR_PLAN=S5

# partition_key 的分区数（仅 S5 生效）。10 个 kbId hash 到 16 分区基本 1KB≈1分区
NUM_PARTITIONS=16


# ----------------------------------------------------------------------------
# 【常改 · 推荐放 .env】稀疏向量 / 多路召回
# ----------------------------------------------------------------------------
# 开关。false 时 collection 不会有 sparse_embedding 字段，Q6 不可用
ENABLE_SPARSE=true
# 词表大小（max token id 范围）
SPARSE_VOCAB=30000
# 每行非零项数（插入侧）。BM25 ~ 几十；SPLADE 蒸馏后 ~ 64~300
SPARSE_NNZ=64
# 每个查询稀疏向量的非零数（一般比插入侧小）
SPARSE_QUERY_NNZ=32
# Rank 融合方式：RRF / WEIGHTED
HYBRID_RANKER=RRF
RRF_K=60
WEIGHT_DENSE=1.0
WEIGHT_SPARSE=1.0


# ----------------------------------------------------------------------------
# 【偶尔调 · 也可只用 CLI】查询参数
# ----------------------------------------------------------------------------
TOPK=10
NQ=1
WARMUP=100
SERIAL_ITERS=1000
SEARCH_EF=64
NPROBE=16
CONC_DUR=60


# ----------------------------------------------------------------------------
# 【偶尔调】测试一 · Collection 上限
# ----------------------------------------------------------------------------
COLL_LIMIT_TARGET=5000
COLL_LIMIT_SAMPLE=50
COLL_LIMIT_MIN_DIM=8


# ----------------------------------------------------------------------------
# 【高级 · 默认即可】mmap 与稀疏索引类型
# ----------------------------------------------------------------------------
# Milvus standalone 在 3072 dim × 10M 行场景下推荐开启 mmap，否则容易 OOM
# 注意：这个变量目前只写到 manifest 供参考，真正生效需要在 milvus.yaml 里设置
MMAP_ENABLED=false
SPARSE_INDEX=SPARSE_INVERTED_INDEX


# ============================================================================
# 【暂未启用 · 预留给后续真实 embedding 召回率验证】
# ----------------------------------------------------------------------------
# 当前所有 dense 向量都是随机 numpy 生成的，纯做性能测试。
# 如果后续要用真实文本 -> embedding 做召回率（recall@K）验证，再启用下面这些。
# ----------------------------------------------------------------------------
# AZURE_EMBEDDING_DEPLOYMENT_NAME=text-embedding-3-large
# AZURE_OPENAI_EMBEDDING_ENDPOINT=https://your-resource.services.ai.azure.com/
# AZURE_OPENAI_EMBEDDING_API_KEY=<secret>
# AZURE_OPENAI_API_VERSION=2024-10-21
